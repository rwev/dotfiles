{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.claude/output-styles/my-humble-servant.md"
  ],
  "permission": {
    "read": {
      "**/.env": "deny",
      "**/.env.*": "deny",
      "secrets/**": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/id_rsa": "deny",
      "**/id_ed25519": "deny",
      "**/credentials.json": "deny",
      "~/.ssh/**": "deny",
      "~/.aws/credentials": "deny"
    }
  }
}
